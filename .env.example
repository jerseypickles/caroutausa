# OpenAI — key para gpt-image-2 (images.edit)
OPENAI_API_KEY=sk-...

# Mongo — conexion. En local puede ser mongodb://127.0.0.1:27017/carota
MONGODB_URI=mongodb://127.0.0.1:27017/carota

# Render inyecta PORT en prod; en local default 3000
PORT=3000

# Modelo de imagenes. Default gpt-image-2; bajar a gpt-image-1-mini para abaratar.
IMAGE_MODEL=gpt-image-2

# Juez de fidelidad (vision): compara la generada vs el jean original.
JUDGE_MODEL=gpt-5.1
FIDELITY_PASS=85

# Receta por producto: por cada angulo, 1 fiel (sin ref) + 1 vibe (con ref)
RECIPE_ANGLES=realista,gancho_click
# Reintentos automaticos cuando el juez marca fail (0 = desactivado)
FIDELITY_RETRIES=1
# Cron de sincronizacion con Shopify
SYNC_INTERVAL_MIN=10
